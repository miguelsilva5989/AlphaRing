{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 27,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "mingw-release",
      "displayName": "MinGW-w64 Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-mingw",
      "toolchainFile": "${sourceDir}/cmake/toolchains/mingw-w64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ALPHARING_DEVTOOLS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "mingw-release",
      "configurePreset": "mingw-release"
    }
  ]
}
